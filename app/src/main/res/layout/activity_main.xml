<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.fitme360.app.ClothOverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomSheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_status"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom sheet: garment-type selector, fit sliders, and action buttons -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Garment type selector: Upper / Lower / Overall -->
        <LinearLayout
            android:id="@+id/garmentTypeBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="14dp">

            <Button
                android:id="@+id/upperBodyButton"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:background="@drawable/bg_pill"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="Upper Body" />

            <Button
                android:id="@+id/lowerBodyButton"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:minWidth="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:background="@drawable/bg_pill"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="Lower Body" />

            <Button
                android:id="@+id/overallBodyButton"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:minWidth="0dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:background="@drawable/bg_pill"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="Overall" />
        </LinearLayout>

        <!-- Fit adjustment sliders -->
        <LinearLayout
            android:id="@+id/adjustBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/topOffsetLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:text="Collar/Waist Offset: 0.15" />

            <SeekBar
                android:id="@+id/topOffsetSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/accent_blue"
                android:thumbTint="@color/accent_blue"
                android:max="80"
                android:progress="45" />

            <TextView
                android:id="@+id/garmentScaleXLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:text="Garment Width: 1.00x" />

            <SeekBar
                android:id="@+id/garmentScaleXSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/accent_blue"
                android:thumbTint="@color/accent_blue"
                android:max="250"
                android:progress="50" />

            <TextView
                android:id="@+id/garmentScaleYLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:text="Garment Height: 1.00x" />

            <SeekBar
                android:id="@+id/garmentScaleYSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/accent_blue"
                android:thumbTint="@color/accent_blue"
                android:max="250"
                android:progress="50" />
        </LinearLayout>

        <!-- Action buttons: scrollable so they all fit on narrow screens -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/controlsBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/pickGarmentButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:background="@drawable/bg_action_button"
                    android:backgroundTint="@color/accent_blue"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:text="🖼️ Pick Garment" />

                <Button
                    android:id="@+id/switchCameraButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:background="@drawable/bg_action_button"
                    android:backgroundTint="@color/accent_blue"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:text="🔄 Camera: Front" />

                <Button
                    android:id="@+id/capturePhotoButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:background="@drawable/bg_action_button"
                    android:backgroundTint="@color/accent_green"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:text="📷 Capture" />

                <Button
                    android:id="@+id/debugToggleButton"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:background="@drawable/bg_action_button"
                    android:backgroundTint="@color/accent_blue"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:text="Debug: OFF" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
